# YK-VOS 测试环境 (.env) —— 用法：cp .env.example .env 后按实际填写
# docker compose 在 release/dev/ 目录下会自动加载 .env

# ══════════════════════════════════════════════════════════════════
# ── 【推送模式】Kafka 对外广播地址（关键！）──
# 推送模式下 VOS 本机的 agent 会「出站」连服务端 Kafka 的 EXTERNAL 端口(9094)推话单。
# Kafka 握手时会把这里配的 advertised 地址回给 agent，agent 再按此地址建连——
# 所以这里必须填「VOS 的 agent 能访问到的服务端 IP/域名」（公网 IP 或双方内网互通的内网 IP）。
# 填错(如保持 127.0.0.1)会导致 agent 连不上、推不进来。
YK_KAFKA_ADVERTISED_HOST=120.226.208.2
# ══════════════════════════════════════════════════════════════════

# ── 多节点 VOS agent 拉取端点（仅“拉取/双向”拓扑用；纯推送模式可忽略）──
# 每台 VOS 一个 agent；格式 name=url，逗号分隔。
# name 即 vos_id，须与对应 agent 的 config.yaml instance.id 完全一致。
NODES=vos1=http://<VOS1公网IP>:5233,vos2=http://<VOS2公网IP>:5233

# ── ClickHouse HTTP 接口 ──
# 容器网络内用服务名 clickhouse；若在本机查库用 127.0.0.1:8123
CLICKHOUSE_URL=http://clickhouse:8123

# ── ODS 表名（按 (vos_id, flowno) 去重）──
CH_TABLE=vos_cdr_ods

# ── agent 鉴权 ──
# 若 VOS agent 启用了 server.token（Bearer 鉴权），填与 agent 同值；空=不鉴权（公网端口强烈建议填值）
MONITOR_TOKEN=

# ── 监控页 ──
PORT=8088
CACHE_SECONDS=8

# ── 应用层（前后端，固定默认值，详见 docker-compose.yaml）──
# 后端 yudao：MySQL(库 ruoyi-vue-pro / 用户 root / 密码 123456) + Redis(6379 / db 1)，端口 48080，API 前缀 /admin-api
# 前端 nginx：端口 3000，反代 /admin-api -> backend:48080
# 如需改库名/密码，直接改 docker-compose.yaml 里 backend 服务的 SPRING_DATASOURCE_* 环境变量即可。
# 默认管理员账号：admin / admin123（yudao 内置，首次登录后请改密）
# 注意：本合并包为「标准 yudao 后台」，不含话单查询/VOS 管理等定制页（那些在另一仓库 yk-vos 的 FastAPI+web-ele）。
