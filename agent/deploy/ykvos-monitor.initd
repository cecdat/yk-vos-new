#!/bin/bash
# chkconfig: 2345 50 50
# description: YK-VOS agent 看门狗，进程退出后自动拉起
# 对应 docs/VOS同步Agent规格.md §2。形态与参考实现 capture 的 monitor 一致。
# 安装位置： /etc/init.d/ykvos-monitor  （由 deploy/install.sh 拷贝）

APP=ykvos-agent
PIDFILE=/var/run/$APP.pid
MONPID=/var/run/$APP-monitor.pid
MONLOG=/var/log/$APP-monitor.log
SVC=/etc/init.d/$APP

loop() {
    while true; do
        if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
            :
        else
            echo "$(date '+%F %T') monitor: $APP 未运行，尝试拉起" >> "$MONLOG"
            "$SVC" start >> "$MONLOG" 2>&1
        fi
        sleep 30
    done
}

start() {
    echo -n "启动看门狗: "
    if [ -f "$MONPID" ] && kill -0 "$(cat "$MONPID")" 2>/dev/null; then
        echo "已在运行"
        return 1
    fi
    nohup "$0" loop >> "$MONLOG" 2>&1 &
    echo $! > "$MONPID"
    echo "完成 (PID: $(cat "$MONPID"))"
}

stop() {
    echo -n "停止看门狗: "
    [ -f "$MONPID" ] || { echo "未运行"; return 1; }
    kill "$(cat "$MONPID")" 2>/dev/null || true
    rm -f "$MONPID"
    echo "完成"
}

restart() { stop; sleep 1; start; }

status() {
    if [ -f "$MONPID" ] && kill -0 "$(cat "$MONPID")" 2>/dev/null; then
        echo "看门狗运行中 (PID: $(cat "$MONPID"))"
    else
        echo "看门狗已停止"
    fi
}

case "$1" in
    start)   start ;;
    stop)    stop ;;
    restart) restart ;;
    status)  status ;;
    loop)    loop ;;
    *) echo "用法: $0 {start|stop|restart|status}"; exit 1 ;;
esac
